{
  "name": "@polyhedral-nets/web",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "svelte-kit sync && eslint src --ext .ts,.js --max-warnings=0 && svelte-check --tsconfig ./tsconfig.json",
    "test": "sh -c 'set -e; files=\"$(find src -type f -name \"*.test.ts\")\"; if [ -z \"$files\" ]; then echo \"No web tests found\"; exit 0; fi; node --import tsx --test $files'"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.19.2",
    "svelte-check": "^4.1.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.1.0"
  },
  "dependencies": {
    "@polyhedral-nets/geometry-engine": "0.1.0",
    "@polyhedral-nets/shared-types": "0.1.0",
    "jszip": "^3.10.1"
  }
}
